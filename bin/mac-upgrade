#!/usr/bin/env zsh

if ! command -v brew &> /dev/null
then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

printf "\e[1;34m%s\e[0m\n" "🍺 Brew update and upgrade"
brew update && brew upgrade && brew upgrade --cask --greedy
brew cleanup && brew autoremove && brew doctor

if [[ -f "/opt/homebrew/opt/antidote/share/antidote/antidote.zsh" ]]; then
  printf "\e[1;34m%s\e[0m\n" "Antidote update"
  source "/opt/homebrew/opt/antidote/share/antidote/antidote.zsh"
  antidote update
fi

printf "\e[1;34m%s\e[0m\n" "💻 Update macOS"
softwareupdate -i -a

# VS Code and Cursor extensions update
if command -v code &>/dev/null; then
  printf "\e[1;34m%s\e[0m\n" "💻 VS Code extensions update"
  code --update-extensions
fi

if command -v cursor &>/dev/null; then
  printf "\e[1;34m%s\e[0m\n" "💻 Cursor extensions update"
  cursor --update-extensions
fi

if command -v mas &>/dev/null; then
  printf "\e[1;34m%s\e[0m\n" "💻 Mac App Store apps update"
  mas upgrade
fi

printf "\e[1;32m%s\e[0m\n" "✅ Done! Your system is up to date!"