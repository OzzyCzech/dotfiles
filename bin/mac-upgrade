#!/usr/bin/env zsh

section() { printf "\n\e[1;34m▶ %s\e[0m\n" "$1" }
ok()      { printf "\e[1;32m✓ %s\e[0m\n" "$1" }

if ! command -v brew &>/dev/null; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

section "Homebrew update"
brew update

section "Homebrew upgrade (formulae)"
brew upgrade --yes

section "Homebrew upgrade (casks, greedy)"
brew upgrade --cask --greedy --yes

section "Homebrew maintenance"
brew cleanup
brew autoremove
brew doctor || true

if [[ -f "/opt/homebrew/opt/antidote/share/antidote/antidote.zsh" ]]; then
  section "Antidote update"
  source "/opt/homebrew/opt/antidote/share/antidote/antidote.zsh"
  antidote update
fi

if command -v npm &>/dev/null; then
  section "npm global packages"
  npm update -g
fi

if command -v bun &>/dev/null; then
  section "bun global packages"
  bun update -g
fi

section "macOS software update"
softwareupdate -i -a

if command -v cursor &>/dev/null; then
  section "Cursor extensions"
  NODE_NO_WARNINGS=1 cursor --update-extensions
fi

ok "Done! Your system is up to date."
